# ── Creative Test Agent — Server Environment ──────────────────────
# Copy this file to .env.server and adjust for your deployment.

# Environment
CTA_ENV=server
CTA_HOST=0.0.0.0
CTA_PORT=8000
CTA_PUBLIC_BASE_URL=http://localhost:8000

# Closed-loop & Providers
CTA_LOCAL_ONLY_MODE=true
CTA_ALLOW_CLOUD_LLM=false
CTA_LLM_PROVIDER=stub
CTA_VISION_PROVIDER=stub
CTA_ENABLE_LOCAL_OCR=false
CTA_ENABLE_LOCAL_VLM=false

# Feature Flags
CTA_ENABLE_AUTH=true
CTA_ENABLE_ADMIN=true
CTA_ENABLE_PROJECTS=true
CTA_ENABLE_BRANDBOOKS=true
CTA_ENABLE_ADVANCED_EXPORTS=true

# Auth & Security
CTA_SECRET_KEY=change-this-secret-key
CTA_SESSION_COOKIE_NAME=cta_session
CTA_SESSION_TTL_HOURS=12
CTA_PASSWORD_MIN_LENGTH=10
CTA_TRUSTED_HOSTS=localhost,127.0.0.1
CTA_CORS_ALLOWED_ORIGINS=

# Bootstrap Admin
CTA_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
CTA_BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
CTA_BOOTSTRAP_ADMIN_NAME=Admin

# Paths
CTA_DATABASE_URL=sqlite:///./data/db/creative_test_agent.db
CTA_STORAGE_ROOT=./data/storage
CTA_EXPORTS_ROOT=./data/exports
CTA_BACKUP_ROOT=./data/backups

# Backup
CTA_BACKUP_INCLUDE_UPLOADS=true
CTA_BACKUP_INCLUDE_EXPORTS=true

# Logging
CTA_LOG_LEVEL=INFO
CTA_LOG_FORMAT=plain
CTA_LOG_FILE=

# Knowledge Base
CTA_ENABLE_KNOWLEDGE_AUTO_INGEST=true
CTA_KB_CHUNK_SIZE_CHARS=1200
CTA_KB_CHUNK_OVERLAP_CHARS=150
CTA_KB_CONTEXT_MAX_ITEMS=8
CTA_KB_CONTEXT_MAX_CHARS=6000

# Prompt tracing
CTA_ENABLE_PROMPT_TRACING=true
CTA_PROMPT_TRACE_STORE_FULL=false
CTA_PROMPT_TRACE_PREVIEW_CHARS=2000
CTA_PROMPT_TRACE_MAX_FULL_CHARS=20000

# Evaluation thresholds
CTA_EVAL_MAX_REPAIR_COUNT=2
CTA_EVAL_MAX_FALLBACK_COUNT=0
