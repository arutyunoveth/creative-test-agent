CTA_DEBUG=false
CTA_DATABASE_URL=sqlite:///./creative_test_agent.db
CTA_LOCAL_ONLY_MODE=true
CTA_ALLOW_CLOUD_LLM=false
CTA_LLM_PROVIDER=stub
CTA_LLM_MODEL=
CTA_LLM_BASE_URL=
CTA_LLM_TIMEOUT_SECONDS=60
CTA_STORAGE_ROOT=./data/storage
CTA_MAX_UPLOAD_SIZE_MB=25
CTA_ALLOWED_UPLOAD_TYPES=txt,md,pdf,png,jpg,jpeg,webp
CTA_RUN_LOCAL_LLM_SMOKE_TESTS=false
CTA_VISION_PROVIDER=stub
CTA_ENABLE_LOCAL_OCR=false
CTA_ENABLE_LOCAL_VLM=false
CTA_VISION_MODEL=
CTA_VISION_BASE_URL=
CTA_VISION_TIMEOUT_SECONDS=60
CTA_RUN_LOCAL_VISION_SMOKE_TESTS=false

CTA_ENV=local
CTA_HOST=127.0.0.1
CTA_PORT=8000
CTA_PUBLIC_BASE_URL=http://localhost:8000
CTA_SECRET_KEY=
CTA_ENABLE_AUTH=false
CTA_ENABLE_ADMIN=false
CTA_ENABLE_PROJECTS=false
CTA_ENABLE_BRANDBOOKS=false
CTA_ENABLE_ADVANCED_EXPORTS=false
CTA_EXPORTS_ROOT=./data/exports
CTA_CORS_ALLOWED_ORIGINS=
CTA_TRUSTED_HOSTS=localhost,127.0.0.1
CTA_SESSION_COOKIE_NAME=cta_session
CTA_SESSION_TTL_HOURS=12
CTA_PASSWORD_MIN_LENGTH=10
CTA_BOOTSTRAP_ADMIN_EMAIL=
CTA_BOOTSTRAP_ADMIN_PASSWORD=
CTA_BOOTSTRAP_ADMIN_NAME=Admin

# Ollama example:
# CTA_LLM_PROVIDER=ollama
# CTA_LLM_MODEL=qwen3:8b
# CTA_LLM_BASE_URL=http://localhost:11434

# LM Studio example:
# CTA_LLM_PROVIDER=lmstudio
# CTA_LLM_MODEL=local-model
# CTA_LLM_BASE_URL=http://localhost:1234/v1

# Local OCR example:
# CTA_VISION_PROVIDER=local_ocr
# CTA_ENABLE_LOCAL_OCR=true

# Local VLM example:
# CTA_VISION_PROVIDER=local_vlm
# CTA_ENABLE_LOCAL_VLM=true
# CTA_VISION_BASE_URL=http://localhost:11434
# CTA_VISION_MODEL=qwen3-vl:8b

# Hybrid example:
# CTA_VISION_PROVIDER=hybrid
# CTA_ENABLE_LOCAL_OCR=true
# CTA_ENABLE_LOCAL_VLM=true

# Prompt tracing
# CTA_ENABLE_PROMPT_TRACING=true
# CTA_PROMPT_TRACE_STORE_FULL=false
# CTA_PROMPT_TRACE_PREVIEW_CHARS=2000
# CTA_PROMPT_TRACE_MAX_FULL_CHARS=20000

# Evaluation thresholds
# CTA_EVAL_MAX_REPAIR_COUNT=2
# CTA_EVAL_MAX_FALLBACK_COUNT=0
